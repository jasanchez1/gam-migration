# Google Ad Manager API config for fetchTargetingMaps.js
# Copy to .env and fill in your values.

# Your GAM network code (Admin > Global settings).
GAM_NETWORK_CODE=123456

# Path to the service-account JSON key file.
# The service account must be added as an API user in your GAM network
# (Admin > Global settings > API access).
GAM_SERVICE_ACCOUNT_KEY_FILE=./service-account.json

# Optional: arbitrary application name reported to the API.
GAM_APPLICATION_NAME=GAM Targeting Export

# Optional: GAM API version. Use a currently-supported version
# (GAM deprecates versions roughly a year after release).
GAM_API_VERSION=v202508
